---
import '../styles/global.css';
const { frontmatter } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{frontmatter.title}</title>
  </head>
  <body>
    <nav>
      <a href="/">home</a>
    </nav>
    <slot />
  </body>
</html>

<style is:global>
  .layout { display: flex; gap: 3rem; align-items: flex-start; max-width: 1100px; }
  .left { flex: 1; }
  .right { flex: 0 0 300px; position: sticky; top: 2rem; }
  .right img { width: 100%; display: block; border-radius: 10px; }
  @media (max-width: 700px) {
    .layout { flex-direction: column; }
    .right { flex-basis: auto; position: static; }
  }
</style>