---
import '../styles/global.css';
const { frontmatter } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{frontmatter.title}</title>
  </head>
  <body>
    <nav>
      <a href="/">home</a>
    </nav>
    <slot />
  </body>
</html>

<style is:global>
  .layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-areas: "text photo" "text links";
    gap: 3rem;
    align-items: start;
    max-width: 1200px;
    margin: 0 auto;
  }
  .left { grid-area: text; }
  .photo { grid-area: photo; position: sticky; top: 2rem; }
  .photo img {
    width: 280px;
    max-width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    border-radius: 10px;
  }
  .right { grid-area: links; }
  @media (max-width: 700px) {
    .layout {
      grid-template-columns: 1fr;
      grid-template-areas: "photo" "text" "links";
    }
    .photo { position: static; }
  }
</style>